# ── Blockchain ────────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private keys — use a KMS-backed signer in production; never commit raw keys
DEPLOYER_PRIVATE_KEY=0x...
VERIFIER_PRIVATE_KEY=0x...
VERIFIER_HOT_WALLET=0x...

# ── Smart Contract Addresses (set after deployment) ───────────────────────────
KROXY_ESCROW_ADDRESS=0x...
KROXY_REPUTATION_ADDRESS=0x...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/kroxy

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
KROXY_API_URL=http://localhost:3001
LOG_LEVEL=info   # debug | info | warn | error

# API key authentication (optional in dev; required in production)
# Generate hash: echo -n "your-secret-key" | sha256sum | awk '{print $1}'
API_KEY_HASH=

# ── Demo Agents ───────────────────────────────────────────────────────────────
AGENT_A_PRIVATE_KEY=0x...
KROXY_API_KEY=your-secret-key   # raw key, must match API_KEY_HASH above
AGENT_B_ADDRESS=0x...
AGENT_B_PORT=3002
AGENT_B_QUALITY=0.9   # 0.0–1.0 (set to 0.3 to trigger dispute path)

# ── Nexus Provider Agent ──────────────────────────────────────────────────────
KROXY_AGENT_WALLET=0x...         # Nexus agent wallet address on Base
KROXY_AGENT_PRIVATE_KEY=0x...   # Private key for signing escrow transactions (Base)
NEXUS_PORT=3003
NEXUS_HOST=localhost              # Set to public hostname or Docker service name when deployed
NEXUS_URL=http://localhost:3003   # Full URL where Nexus is reachable (used in condition checks)

# ── Dashboard (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_KROXY_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_KROXY_REPUTATION_ADDRESS=0x...

# ── Court / Arbitration ───────────────────────────────────────────────────────
KROXY_COURT_ADDRESS=0x...

# 3 judge wallets — ephemeral, need small ETH for gas
COURT_JUDGE_1_PRIVATE_KEY=0x...
COURT_JUDGE_2_PRIVATE_KEY=0x...
COURT_JUDGE_3_PRIVATE_KEY=0x...

# ── LLM Judge API Keys ────────────────────────────────────────────────────────
# Judge 1 — Claude (Anthropic) — strongest legal reasoning
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Judge 2 — GPT-4o (OpenAI) — independent second opinion
# Get at: https://platform.openai.com/
OPENAI_API_KEY=sk-...

# Judge 3 — Gemini Flash (Google) — fast tiebreaker
# Get free keys at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY_1=AIza...
GOOGLE_API_KEY_2=AIza...
GOOGLE_API_KEY_3=AIza...
# Falls back to this if KEY_1/2/3 not set
GOOGLE_API_KEY=AIza...

# ── IPFS (optional — evidence falls back to DB if unset) ─────────────────────
PINATA_JWT=

# ── Etherscan / Basescan ──────────────────────────────────────────────────────
BASESCAN_API_KEY=
