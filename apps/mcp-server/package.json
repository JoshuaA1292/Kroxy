{
  "name": "@kroxy/mcp-server",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "bin": {
    "kroxy-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting --no-dts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kroxy/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5"
  }
}
