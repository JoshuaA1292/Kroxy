{
  "name": "@kroxy/api",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kroxy/db": "workspace:*",
    "@kroxy/sdk": "workspace:*",
    "@kroxy/types": "workspace:*",
    "ethers": "^6.13.1",
    "express": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.3.1",
    "pino": "^9.3.1",
    "zod": "^3.23.8",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.67.0",
    "@google/generative-ai": "^0.21.0",
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "ts-node-dev": "^2.0.0",
    "pino-pretty": "^11.2.1",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
